# ─── VirtuGym — Frontend Environment Variables ────────────────────────
#
# Copy this file to `.env.local` and fill in your values.
# VITE_ prefix is required for Vite to expose vars to the browser bundle.
#
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of your Flask REST API backend (no trailing slash).
# Development (local Flask):  http://127.0.0.1:5000/api
VITE_API_URL=http://127.0.0.1:5000/api

# Optional: API request timeout in milliseconds (default: 15000)
# VITE_API_TIMEOUT=15000
